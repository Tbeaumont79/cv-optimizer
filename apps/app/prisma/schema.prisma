// Couche d'accès PostgreSQL (Prisma), utilisée côté serveur Nitro.
// Modèle métier « profil candidat » (THI-123, WS-Auth+Profil) — data model THI-120 §2.
// Périmètre de ce WS : users / profiles / experiences / skills / education.
// Hors périmètre (WS dédiés) : job_offers + generations (THI-124), usage_* (THI-126),
// tables satellites d'auth (sessions/accounts/verification → ajoutées par le WS Auth).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// RGPD-ready (placeholder structurel — cadrage détaillé = THI-120)
// Emplacement prévu pour tracer les actions de gouvernance des données
// personnelles : rétention, suppression (droit à l'effacement), export
// (portabilité). Ce modèle n'est PAS le modèle métier ; il réserve la place
// de la couche conformité que toutes les futures entités personnelles
// référenceront.
// ─────────────────────────────────────────────────────────────────────────────

enum DataGovernanceAction {
  RETENTION_APPLIED // purge selon la durée de conservation
  ERASURE_REQUESTED // droit à l'effacement
  EXPORT_REQUESTED // droit à la portabilité
}

model DataGovernanceEvent {
  id         String               @id @default(uuid())
  action     DataGovernanceAction
  // Référence opaque vers le sujet concerné (ex. userId). Pas de FK tant que
  // le modèle métier n'existe pas — placeholder volontaire.
  subjectRef String?
  createdAt  DateTime             @default(now())

  @@index([action])
  @@map("data_governance_event")
}

// ─────────────────────────────────────────────────────────────────────────────
// Modèle métier — Profil candidat (THI-120 §2 · THI-123)
//
// Garde-fou produit : les compétences/expériences saisies ici sont la SEULE
// source de vérité du futur moteur (THI-124). Aucune invention en aval ; la
// provenance pointera vers ces lignes.
//
// RGPD : soft-delete (`deletedAt`) dès la modélisation. Un `deletedAt` non nul =
// enregistrement supprimé logiquement, à exclure des lectures (cf. `notDeleted`)
// et à purger physiquement par le job de rétention (DataGovernanceEvent).
// ─────────────────────────────────────────────────────────────────────────────

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

// Compte utilisateur — ancre d'authentification (le WS Auth y greffera Better
// Auth + ses tables satellites). Données auth hébergées en FR/UE (RGPD).
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  // Champs compatibles Better Auth (renseignés par le WS Auth) :
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // soft-delete RGPD (droit à l'effacement)

  profile Profile?

  @@index([deletedAt])
  @@map("users")
}

// Profil candidat — 1-1 avec User. En-tête + résumé libres.
model Profile {
  id        String    @id @default(uuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline  String? // intitulé court (ex. « Développeur Full-Stack »)
  summary   String? // résumé / accroche
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  experiences Experience[]
  skills      Skill[]
  education   Education[]

  @@index([deletedAt])
  @@map("profiles")
}

// Expérience professionnelle (n par profil). `orderIndex` = ordre d'affichage saisi.
model Experience {
  id          String    @id @default(uuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  company     String
  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date // null = poste en cours
  description String?
  skillsUsed  String[] // compétences mobilisées, libellés libres déclarés
  orderIndex  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([profileId])
  @@index([deletedAt])
  @@map("experiences")
}

// Compétence RÉELLE déclarée par le candidat (source de vérité du moteur).
model Skill {
  id         String      @id @default(uuid())
  profileId  String
  profile    Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  label      String
  level      SkillLevel?
  years      Int? // années d'expérience déclarées
  orderIndex Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?

  @@index([profileId])
  @@index([deletedAt])
  @@map("skills")
}

// Formation / diplôme (n par profil).
model Education {
  id          String    @id @default(uuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  degree      String
  school      String
  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date
  description String?
  orderIndex  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([profileId])
  @@index([deletedAt])
  @@map("education")
}

// Metering — usage_events + usage_counters (THI-120 §2 · THI-126)
//
// On mesure l'usage DÈS le MVP (même gratuit) pour préparer le billing freemium.
// `userId` est volontairement un identifiant simple indexé (pas de relation Prisma
// vers `users`) : ce WS reste additif et indépendant de l'ordre de merge des autres
// lots (auth/profil/génération). La contrainte FK pourra être ajoutée plus tard.
//
// RGPD : on stocke des compteurs et des volumes de tokens — JAMAIS le contenu des
// CV ni des offres.
// ─────────────────────────────────────────────────────────────────────────────

enum UsageEventType {
  GENERATION // génération d'un CV (Sonnet/Opus)
  EXPORT_PDF // export PDF d'un CV
  EXTRACTION // analyse / extraction de mots-clés d'une offre (Haiku)

  @@map("usage_event_type")
}

// Événement d'usage unitaire — une ligne par génération / export / extraction.
model UsageEvent {
  id        String         @id @default(uuid())
  userId    String
  type      UsageEventType
  // Période yyyymm dénormalisée (ex. "202606") — facilite l'agrégation / les purges.
  period    String         @db.VarChar(6)
  tokensIn  Int            @default(0)
  tokensOut Int            @default(0)
  // Facturable = compte dans la base billing (freemium). Gratuit ⇒ false au MVP.
  billable  Boolean        @default(false)
  createdAt DateTime       @default(now())

  @@index([userId, period])
  @@index([type])
  @@map("usage_events")
}

// Agrégat d'usage par utilisateur et par période (yyyymm). Incrémenté à chaque
// événement (upsert atomique). Une ligne par (userId, période).
model UsageCounter {
  id              String   @id @default(uuid())
  userId          String
  period          String   @db.VarChar(6)
  generationCount Int      @default(0)
  exportPdfCount  Int      @default(0)
  extractionCount Int      @default(0)
  tokensIn        Int      @default(0)
  tokensOut       Int      @default(0)
  billableCount   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, period])
  @@map("usage_counters")
}
