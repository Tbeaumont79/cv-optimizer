{
  "name": "cv-optimizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CV Optimizer — SaaS web FR de génération de CV adaptés aux offres (monorepo Nuxt 3 full-stack).",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:shared": "pnpm --filter @cvo/shared build",
    "build": "pnpm build:shared && pnpm --filter @cvo/app build",
    "typecheck": "pnpm build:shared && pnpm -r typecheck",
    "test": "pnpm build:shared && pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "dev": "pnpm --filter @cvo/app dev",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vue-eslint-parser": "^9.4.3"
  }
}
